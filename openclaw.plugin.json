{
  "id": "openclaw-wrt",
  "name": "OpenClaw WRT",
  "description": "Accept OpenClaw WRT device WebSocket connections and expose a control tool with req_id correlation.",
  "activation": {
    "onStartup": true,
    "onConfigPaths": [
      "plugins.entries.openclaw-wrt"
    ]
  },
  "contracts": {
    "tools": [
      "claw_wifi_hello",
      "clawwrt",
      "clawwrt_add_xfrpc_tcp_service",
      "clawwrt_auth_client",
      "clawwrt_bpf_add",
      "clawwrt_bpf_del",
      "clawwrt_bpf_flush",
      "clawwrt_bpf_json",
      "clawwrt_bpf_update",
      "clawwrt_bpf_update_all",
      "clawwrt_check_lan_conflict",
      "clawwrt_delete_vpn_routes",
      "clawwrt_delete_wifi_relay",
      "clawwrt_deploy_wireguard_full_mesh",
      "clawwrt_execute_shell",
      "clawwrt_firmware_upgrade",
      "clawwrt_generate_portal_page",
      "clawwrt_generate_wireguard_keys",
      "clawwrt_get_auth_serv",
      "clawwrt_get_br_lan",
      "clawwrt_get_client_info",
      "clawwrt_get_clients",
      "clawwrt_get_device",
      "clawwrt_get_device_info",
      "clawwrt_get_firmware_info",
      "clawwrt_get_l7_active_stats",
      "clawwrt_get_l7_protocol_catalog",
      "clawwrt_get_mqtt_serv",
      "clawwrt_get_network_interfaces",
      "clawwrt_get_speedtest_servers",
      "clawwrt_get_status",
      "clawwrt_get_sys_info",
      "clawwrt_get_trusted_domains",
      "clawwrt_get_trusted_mac",
      "clawwrt_get_trusted_wildcard_domains",
      "clawwrt_get_vpn_routes",
      "clawwrt_get_websocket_serv",
      "clawwrt_get_wifi_info",
      "clawwrt_get_wireguard_vpn",
      "clawwrt_get_wireguard_vpn_status",
      "clawwrt_get_xfrpc_config",
      "clawwrt_join_wireguard_lan_mesh",
      "clawwrt_kickoff_client",
      "clawwrt_list_devices",
      "clawwrt_plan_wireguard_client_routes",
      "clawwrt_publish_portal_page",
      "clawwrt_reboot_device",
      "clawwrt_reconcile_wireguard_lan_mesh",
      "clawwrt_reset_wireguard_vpn",
      "clawwrt_restart_xfrpc",
      "clawwrt_scan_wifi",
      "clawwrt_set_auth_serv",
      "clawwrt_set_br_lan",
      "clawwrt_set_mqtt_serv",
      "clawwrt_set_vpn_domain_routes",
      "clawwrt_set_vpn_routes",
      "clawwrt_set_websocket_serv",
      "clawwrt_set_wifi_info",
      "clawwrt_set_wifi_relay",
      "clawwrt_set_wireguard_vpn",
      "clawwrt_set_xfrpc_common",
      "clawwrt_setup_server_vpn_nat",
      "clawwrt_speedtest",
      "clawwrt_sync_trusted_domains",
      "clawwrt_sync_trusted_mac",
      "clawwrt_sync_trusted_wildcard_domains",
      "clawwrt_tmp_pass_client",
      "clawwrt_update_device_info",
      "clawwrt_verify_wireguard_connectivity",
      "openclaw_add_wg_peer",
      "openclaw_deploy_frps",
      "openclaw_deploy_wg_server",
      "openclaw_get_frps_status",
      "openclaw_get_wg_status",
      "openclaw_reset_frps",
      "openclaw_reset_wg_server"
    ]
  },
  "skills": [
    "./skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "bind": {
        "type": "string"
      },
      "port": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535
      },
      "path": {
        "type": "string"
      },
      "allowDeviceIds": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "requestTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 120000
      },
      "maxPayloadBytes": {
        "type": "integer",
        "minimum": 1024,
        "maximum": 1048576
      },
      "token": {
        "type": "string"
      },
      "awasEnabled": {
        "type": "boolean"
      },
      "awasHost": {
        "type": "string"
      },
      "awasPort": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535
      },
      "awasPath": {
        "type": "string"
      },
      "awasSsl": {
        "type": "boolean"
      }
    }
  }
}
